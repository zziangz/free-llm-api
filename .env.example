# Free LLM API Provider Keys
# Copy this file to .env and fill in your API keys
# Get keys from the URLs listed below

# Google AI Studio (Gemini)
# https://aistudio.google.com/api-keys
GEMINI_API_KEY=your_gemini_api_key

# GitHub Models
# https://github.com/settings/tokens (fine-grained token with Models permission)
# API: https://models.github.ai/inference
GITHUB_TOKEN=github_pat_xxxxxxxxxxxx

# OpenRouter
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# Ollama Cloud
# https://ollama.com/settings/keys
OLLAMA_API_KEY=your_ollama_api_key

# Vercel AI
# https://vercel.com/account/tokens
VERCEL_API_KEY=vck_xxxxxxxxxxxx

# Cerebras
# https://cloud.cerebras.ai/
CEREBRAS_API_KEY=csk-xxxxxxxxxxxx

# NVIDIA NIM
# https://build.nvidia.com/
NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxx

# Cloudflare Workers AI
# https://dash.cloudflare.com/ → AI → Workers AI
CLOUDFLARE_AI_API_KEY=your_cloudflare_api_key
CLOUDFLARE_AI_ACCOUNT_ID=your_cloudflare_account_id

# Mistral
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key

# HuggingFace
# https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxx

# Groq
# https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxx
